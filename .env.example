# Copy this file to .env.local and fill in your real values
# NEVER commit .env.local to version control

# ===== Required: Neon PostgreSQL Database =====
DATABASE_URL=postgresql://user:password@host.eu-west-2.aws.neon.tech/dbname?sslmode=require&channel_binding=require

# ===== Required: Email (Resend) =====
RESEND_API_KEY=re_your_api_key_here
FROM_EMAIL=noreply@yourapp.com

# ===== Required: Superadmin Authentication =====
# Set strong, unique credentials before deploying to production
SUPER_ADMIN_USERNAME=your_username_here
SUPER_ADMIN_PASSWORD=your_very_strong_password_here

# ===== Firebase Configuration (for shop owner auth) =====
# Get these from Firebase Console > Project Settings > General
NEXT_PUBLIC_FIREBASE_API_KEY=your_firebase_api_key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your-project-id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your-project.firebasestorage.app
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
NEXT_PUBLIC_FIREBASE_APP_ID=1:your_app_id:web:your_web_config
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=G-your_measurement_id

# Firebase Admin SDK (for server-side operations)
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nyour_private_key_here\n-----END PRIVATE KEY-----\n"

# ===== Optional: API & Developer Hub Configuration =====
# Webhook settings
WEBHOOK_TIMEOUT_MS=5000
WEBHOOK_FAILURE_THRESHOLD=5

# API Logging
LOG_RETENTION_DAYS=30

# App info
NEXT_PUBLIC_APP_NAME=Graze
NEXT_PUBLIC_APP_TYPE=owned
